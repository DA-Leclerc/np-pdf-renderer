{
  "name": "@nordparadigm/pdf-renderer",
  "version": "0.1.4",
  "description": "Shared PDF rendering pipeline for Nord Paradigm products (Radar, Brèche, future). Headless Chromium + Handlebars templates.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./templates/*": "./src/templates/*"
  },
  "files": [
    "src/"
