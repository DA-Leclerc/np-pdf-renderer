    "test:radar:fr": "node scripts/render-sample.js radar fr"
  },
  "dependencies": {
    "@sparticuz/chromium": "^147.0.2",
    "handlebars": "^4.7.8",
    "puppeteer-core": "^24.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DA-Leclerc/np-pdf-renderer.git"
  },
  "license": "UNLICENSED",
  "private": false
}
